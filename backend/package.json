{
  "name": "plumio-backend",
  "version": "2.10.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate-cli.ts",
    "migrate:status": "tsx src/db/migrate-cli.ts status",
    "migrate:run": "tsx src/db/migrate-cli.ts run",
    "migrate:create": "tsx src/db/migrate-cli.ts create",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.782.0",
    "@hono/node-server": "^1.19.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "hono": "^4.12.25",
    "jose": "^5.10.0",
    "nodemailer": "^8.0.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
