{
  "name": "plumio-backend",
  "version": "2.6.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate-cli.ts",
    "migrate:status": "tsx src/db/migrate-cli.ts status",
    "migrate:run": "tsx src/db/migrate-cli.ts run",
    "migrate:create": "tsx src/db/migrate-cli.ts create",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "hono": "^4.12.12",
    "jose": "^5.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
